    <div class="menu-overlay" id="menu-overlay">
        <div class="menu-nav">
            <a href="../index.html#portfolio" class="menu-link">PORTFOLIO</a>
            <a href="../index.html#lab" class="menu-link">THE LAB</a>
            <a href="../index.html#about" class="menu-link">ABOUT</a>
            <a href="../index.html#contact" class="menu-link">CONTACT</a>
        </div>
        <div class="mobile-menu-actions">
            <a href="https://www.linkedin.com/in/nitin-kr-205341b/" class="ds-btn ds-btn-primary" target="_blank">LinkedIn</a>
            <a href="https://drive.google.com/file/d/1QZ3t9m-rhyUR12MwxylxgyfCBWVkjNqZ/view?usp=sharing" class="ds-btn ds-btn-secondary" target="_blank">Resume</a>
        </div>
    </div>

    <script src="../assets/js/main.js"></script>
    <script>
        // --- High-Fidelity Theme Toggle (Independent) ---
        function handleThemeToggle() {
            const html = document.documentElement;
            const body = document.body;
            const toggleBtn = document.getElementById('cs-theme-toggle');
            
            if (!toggleBtn) return;

            const isDark = html.classList.toggle('dark-mode');
            body.classList.toggle('dark-mode');
            
            const theme = isDark ? 'dark' : 'light';
            html.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
            
            // Update Icons
            const moon = toggleBtn.querySelector('.moon-icon');
            const sun = toggleBtn.querySelector('.sun-icon');
            if (moon && sun) {
                moon.style.display = isDark ? 'none' : 'block';
                sun.style.display = isDark ? 'block' : 'none';
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('cs-theme-toggle');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', handleThemeToggle);
                
                // Initial Icon Sync
                const isDark = document.documentElement.classList.contains('dark-mode');
                const moon = toggleBtn.querySelector('.moon-icon');
                const sun = toggleBtn.querySelector('.sun-icon');
                if (moon && sun) {
                    moon.style.display = isDark ? 'none' : 'block';
                    sun.style.display = isDark ? 'block' : 'none';
                }
            }

            // Accordion Logic
            const sections = document.querySelectorAll('.cs-section');
            sections.forEach(section => {
                const header = section.querySelector('.cs-section-header');
                header.addEventListener('click', () => {
                    section.classList.toggle('cs-expanded');
                });
            });
            // Expand first section by default
            if (sections.length > 0) sections[0].classList.add('cs-expanded');

            // Reveal on Scroll
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

            // --- High-Fidelity Interface Slider Engine ---
            const initHifiSlider = (id) => {
                const slider = document.getElementById(id);
                if (!slider) return;
                
                const slides = slider.querySelectorAll('.hifi-slide');
                if (slides.length === 0) return;

                let currentIdx = 0;
                let sliderInterval;

                const updateHifiSlider = (index) => {
                    slides.forEach((slide, i) => {
                        if (i === index) {
                            slide.style.visibility = 'visible';
                            slide.style.opacity = '1';
                            slide.classList.add('active');
                        } else {
                            slide.style.opacity = '0';
                            slide.classList.remove('active');
                            setTimeout(() => {
                                if (!slide.classList.contains('active')) {
                                    slide.style.visibility = 'hidden';
                                }
                            }, 800);
                        }
                    });
                    currentIdx = index;
                };

                const startAutoSlide = () => {
                    sliderInterval = setInterval(() => {
                        let next = (currentIdx + 1) % slides.length;
                        updateHifiSlider(next);
                    }, 4000);
                };

                startAutoSlide();
            };

            // --- Mobile Horizontal Auto-Slider Engine ---
            const initMobileSlider = () => {
                const container = document.getElementById('hifi-slider-mobile');
                if (!container) return;
                
                const slides = container.querySelectorAll('.hifi-mobile-slide');
                if (slides.length === 0) return;

                let currentIdx = 0;
                let autoSlideInterval;

                const startAutoSlide = () => {
                    autoSlideInterval = setInterval(() => {
                        currentIdx = (currentIdx + 1) % slides.length;
                        const itemWidth = slides[0].offsetWidth + 32; // width + gap
                        container.scrollTo({
                            left: currentIdx * itemWidth,
                            behavior: 'smooth'
                        });
                    }, 4000);
                };

                // Pause on user interaction
                container.addEventListener('touchstart', () => clearInterval(autoSlideInterval));
                container.addEventListener('mousedown', () => clearInterval(autoSlideInterval));

                startAutoSlide();
            };

            initHifiSlider('hifi-slider-web');
            initMobileSlider();
        });
    </script>
</body>

</html>