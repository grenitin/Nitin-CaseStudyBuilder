                                </div>
                            </div>
                            <div class="hifi-mobile-slide" style="flex: 0 0 auto; width: 280px; height: 580px; scroll-snap-align: center; overflow: hidden; border-radius: 36px; border: 8px solid #1a1a1a; background: #000; box-shadow: 0 30px 60px rgba(0,0,0,0.5); position: relative;">
                                <div style="width: 100%; height: 100%; overflow-y: auto; scrollbar-width: none; -ms-overflow-style: none;">
                                    <img src="image/High-Fidelity%20Interface/Mobile/106956641dfd4b7e8a4b8570f7d0d8c8.png" alt="FIPA Mobile 2" style="width: 100%; height: auto; display: block;" />
                                </div>
                            </div>
                            <div class="hifi-mobile-slide" style="flex: 0 0 auto; width: 280px; height: 580px; scroll-snap-align: center; overflow: hidden; border-radius: 36px; border: 8px solid #1a1a1a; background: #000; box-shadow: 0 30px 60px rgba(0,0,0,0.5); position: relative;">
                                <div style="width: 100%; height: 100%; overflow-y: auto; scrollbar-width: none; -ms-overflow-style: none;">
                                    <img src="image/High-Fidelity%20Interface/Mobile/228c48af2b3d416dacb1d4c110c8a224.png" alt="FIPA Mobile 3" style="width: 100%; height: auto; display: block;" />
                                </div>
                            </div>
                            <div class="hifi-mobile-slide" style="flex: 0 0 auto; width: 280px; height: 580px; scroll-snap-align: center; overflow: hidden; border-radius: 36px; border: 8px solid #1a1a1a; background: #000; box-shadow: 0 30px 60px rgba(0,0,0,0.5); position: relative;">
                                <div style="width: 100%; height: 100%; overflow-y: auto; scrollbar-width: none; -ms-overflow-style: none;">
                                    <img src="image/High-Fidelity%20Interface/Mobile/41640a32516245f9ad459d78071ffe14.png" alt="FIPA Mobile 4" style="width: 100%; height: auto; display: block;" />
                                </div>
                            </div>
                            <div class="hifi-mobile-slide" style="flex: 0 0 auto; width: 280px; height: 580px; scroll-snap-align: center; overflow: hidden; border-radius: 36px; border: 8px solid #1a1a1a; background: #000; box-shadow: 0 30px 60px rgba(0,0,0,0.5); position: relative;">
                                <div style="width: 100%; height: 100%; overflow-y: auto; scrollbar-width: none; -ms-overflow-style: none;">
                                    <img src="image/High-Fidelity%20Interface/Mobile/48bc077f67f43af90708e4d22883f1a.png" alt="FIPA Mobile 5" style="width: 100%; height: auto; display: block;" />
                                </div>
                            </div>
                            <div class="hifi-mobile-slide" style="flex: 0 0 auto; width: 280px; height: 580px; scroll-snap-align: center; overflow: hidden; border-radius: 36px; border: 8px solid #1a1a1a; background: #000; box-shadow: 0 30px 60px rgba(0,0,0,0.5); position: relative;">
                                <div style="width: 100%; height: 100%; overflow-y: auto; scrollbar-width: none; -ms-overflow-style: none;">
                                    <img src="image/High-Fidelity%20Interface/Mobile/50e5d9bdf9df4eb0b849a2d5f9db09e5.png" alt="FIPA Mobile 6" style="width: 100%; height: auto; display: block;" />
                        </div>

                        <!-- Integrated Slider Controls & Actions -->
                        <div class="hifi-controls-wrapper" style="position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; z-index: 11; width: 100%;">
                            <div class="hifi-quick-actions" style="display: flex; justify-content: center; gap: 15px;">
                                <a href="https://marvelapp.com/prototype/6i0j88g/screen/77156766" target="_blank" class="hifi-action-btn" style="display: flex; align-items: center; gap: 8px; background: var(--accent); color: #1A1A1A; padding: 12px 24px; border-radius: 30px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; text-decoration: none; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 10px 20px rgba(var(--primary-rgb), 0.3);">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                                    Mobile App Interface
                                </a>
                            </div>
                        </div>

                        <style>
                            #hifi-slider-mobile::-webkit-scrollbar { display: none; }
                            #hifi-slider-mobile { -ms-overflow-style: none; scrollbar-width: none; }
                        </style>
                    </div>
                </div>
            </section>

            <!-- 5. TEST & ITERATE -->
            <section class="cs-section reveal">
                <div class="cs-section-header">
                    <div class="cs-section-marker">T</div>
                    <h2 class="ds-heading-h2">Let's Evaluate</h2>

                    <p>Validating assumptions through usability testing and refining the interface.</p>
                </div>
                <div class="cs-section-content">
                    <h3 class="ds-heading-h3 cs-section-subtitle">Before vs After</h3>
                    <div class="cs-grid-2 carousel-mobile cs-comparison-grid">
                        <div class="cs-arch-container cs-comparison-card"
                            style="padding: 0; min-height: 400px; display: flex; flex-direction: column; position: relative;">
                            <div class="cs-comparison-label label-before">Before: High Friction</div>
                            <div class="cs-comparison-placeholder">
                                <span class="placeholder-text">Old UI Placeholder</span>
                            </div>
                        </div>
                        <div class="cs-arch-container cs-comparison-card"
                            style="padding: 0; min-height: 400px; display: flex; flex-direction: column; position: relative;">
                            <div class="cs-comparison-label label-after">After: Streamlined</div>
                            <div class="cs-comparison-placeholder">
                                <span class="placeholder-text">New UI Placeholder</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 6. FINAL REFLECTIONS -->
            <section class="cs-section reveal">
                <div class="cs-section-header">
                    <div class="cs-section-marker">R</div>
                    <h2 class="ds-heading-h2">Final Reflections</h2>
                    <p>Analyzing the design maturity, strategic impact, and key lessons learned.</p>
                </div>
                <div class="cs-section-content">
                    <!-- Delivery Impact Metrics -->
                    <div class="cs-grid-3" style="margin-bottom: 4rem;">
                        {% for metric in impact_metrics %}
                        <div class="cs-metric-card"
                            style="display: flex; align-items: center; justify-content: space-between; padding: 2.5rem; background: var(--bg-card); border-radius: 18px; border: 1px solid var(--border-medium);">
                            <div style="width: 80px;">
                                <svg viewBox="0 0 100 60" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 100%;">
                                    <path d="M10 50 L30 40 L50 45 L70 20 L90 10" stroke="var(--accent)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                    <path d="M80 10 H90 V20" stroke="var(--accent)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                            </div>
                            <div style="text-align: right;">
                                <div class="cs-metric-val" style="font-size: 2.5rem; color: var(--accent); font-weight: 800;">{{ metric.value }}</div>
                                <div class="cs-metric-label" style="color: var(--text-secondary); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">{{ metric.label }}</div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>

                    <!-- Strategic Takeaways -->
                    <div class="cs-grid-3">
                        {% for takeaway in strategic_takeaways %}
                        <div class="ds-card">
                            <h4 class="cs-affinity-theme" style="text-align: left; margin-bottom: 1rem;">{{ takeaway.title }}</h4>
                            <p style="margin-bottom: 1rem;"><strong class="cs-affinity-theme">Pros:</strong> {{ takeaway.pros }}</p>
                            <p><strong class="cs-affinity-theme">Cons:</strong> {{ takeaway.cons }}</p>
                        </div>
                        {% endfor %}
                    </div>
                            <p style="margin-bottom: 1rem;"><strong class="cs-affinity-theme">Pros:</strong> Familiarity among older staff, stable performance.</p>
                            <p><strong class="cs-affinity-theme">Cons:</strong> No API integrations, manual data entry required.</p>
                        </div>
                    </div>
                </div>
            </section>

        </div>
    </main>

    <footer class="cs-footer">
        <div class="cs-footer-container">
            <p>© 2026 Nitin Kr. • UX Case Study Portfolio</p>
        </div>
    </footer>

